?>

<a x-data x-show="$store.compare && $store.compare.items.length > 0"
   id="compare-link"
   class="relative md:inline-flex btn bg-transparent border-transparent p-1 "
   x-cloak
   href="<?= $escaper->escapeUrl($block->getUrl('catalog/product_compare/index')) ?>"
