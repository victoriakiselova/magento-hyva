    <span
        x-text="$store.compare.items.length"
        class="absolute -top-1.5 -right-1.5 px-2 py-1 rounded-full bg-primary text-on-primary
            text-xs font-semibold leading-none text-center uppercase tabular-nums"
        aria-hidden="true"
    ></span>
</a>
