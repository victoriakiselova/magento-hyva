<?xml version="1.0"?>

<page layout="3columns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="default_head_blocks"/>

    <body>
        <referenceContainer name="main.content">
            <block class="Magento\Framework\View\Element\Template" name="post-form" before="-"
                   template="Magento_Theme::html/form.phtml"/>
            <block class="Magento\Framework\View\Element\Template" name="youtube-video" after="post-form"
                   template="Magento_Theme::youtube.phtml"/>
            <block class="Magento\Framework\View\Element\Template" name="iconList" after="youtube-video"
                   template="Magento_Theme::html/icons.phtml"/>
            <block class="Magento\Framework\View\Element\Template" name="attributes" after="iconList"
                   template="Magento_Theme::html/attributes.phtml"/>
            <block class="Magento\Framework\View\Element\Template" name="use-el" after="attributes"
                   template="Magento_Theme::html/use-of-el.phtml"/>
            <block class="Magento\Framework\View\Element\Template" name="dropdown" after="use-el"
                   template="Magento_Theme::html/dropdown.phtml"/>
            <block class="Magento\Framework\View\Element\Template" name="alpine" after="dropdown"
                   template="Magento_Theme::html/alpine.phtml"/>
        </referenceContainer>
    </body>
</page>
