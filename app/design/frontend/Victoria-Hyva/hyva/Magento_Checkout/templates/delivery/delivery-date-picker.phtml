<?php /** @var \Magento\Framework\Escaper $escaper */
?>

<div x-data="initGetDelivery()" x-init="init()">
    <input type="date" x-model="date" class="mr-3 mb-3 md:mb-0"
           :disabled="optionDelivery === 'pickup' || optionDelivery === 'express'"
           @change="$dispatch('delivery-date-selected', {
        date: $event.target.value
    })">
    <button type="button"
            class="px-4 py-2 text-white text-md leading-normal bg-blue-600 cursor-pointer rounded hover:bg-blue-400 transition-all duration-300"
            @click="date = ''; $dispatch('delivery-date-reset', { date: null})"><?= $escaper->escapeHtmlAttr(__('Reset')) ?></button>
</div>
