<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="checkout.root">
            <arguments>
                <argument name="jsLayout" xsi:type="array">
                    <item name="components" xsi:type="array">
                        <item name="checkout" xsi:type="array">
                            <item name="children" xsi:type="array">
                                <item name="steps" xsi:type="array">
                                    <item name="children" xsi:type="array">
                                        <item name="shipping-step" xsi:type="array">
                                            <item name="component" xsi:type="string">uiComponent</item>
                                            <item name="children" xsi:type="array">
                                                <item name="shippingAddress" xsi:type="array">
                                                    <item name="children" xsi:type="array">
                                                        <item name="before-fields" xsi:type="array">
                                                            <item name="children" xsi:type="array">
                                                                <item name="change-address" xsi:type="array">
                                                                    <item name="component" xsi:type="string">Magento_PaymentServicesPaypal/js/view/form/element/change-address</item>
                                                                    <item name="children" xsi:type="array">
                                                                        <item name="paypal-fastlane-address-watermark" xsi:type="array">
                                                                            <item name="component" xsi:type="string">Magento_PaymentServicesPaypal/js/view/form/element/powered-by</item>
                                                                            <item name="id" xsi:type="string">paypal-fastlane-address-watermark</item>
                                                                            <item name="displayArea" xsi:type="string">paypal-fastlane-address-watermark</item>
                                                                        </item>
                                                                    </item>
                                                                </item>
                                                            </item>
                                                        </item>
                                                        <item name="customer-email" xsi:type="array">
                                                            <item name="template" xsi:type="string">Magento_PaymentServicesPaypal/form/element/email</item>
                                                            <item name="children" xsi:type="array">
                                                                <item name="paypal-fastlane-email-watermark" xsi:type="array">
                                                                    <item name="component" xsi:type="string">Magento_PaymentServicesPaypal/js/view/form/element/powered-by</item>
                                                                    <item name="displayArea" xsi:type="string">paypal-fastlane-email-watermark</item>
                                                                    <item name="id" xsi:type="string">paypal-fastlane-email-watermark</item>
                                                                </item>
                                                            </item>
                                                        </item>
                                                        <item name="payment-services-express-payments" xsi:type="array">
                                                            <item name="component" xsi:type="string">Magento_PaymentServicesPaypal/js/view/payment/group</item>
                                                            <item name="sortOrder" xsi:type="string">0</item>
                                                            <item name="displayArea" xsi:type="string">customer-email</item>
                                                            <item name="children" xsi:type="array">
                                                                <item name="paypal-express-paypal" xsi:type="array">
                                                                    <item name="component" xsi:type="string">Magento_PaymentServicesPaypal/js/view/payment/smart-buttons-express-checkout</item>
                                                                    <item name="displayArea" xsi:type="string">additional-express-payments-paypal</item>
                                                                    <item name="configSource" xsi:type="string">checkoutConfig</item>
                                                                </item>
                                                                <item name="paypal-express-googlepay" xsi:type="array">
                                                                    <item name="component" xsi:type="string">Magento_PaymentServicesPaypal/js/view/payment/google-pay-express-checkout</item>
                                                                    <item name="displayArea" xsi:type="string">additional-express-payments-paypal</item>
                                                                    <item name="configSource" xsi:type="string">checkoutConfig</item>
                                                                    <item name="id" xsi:type="string">paypal-googlepay-container</item>
                                                                </item>
                                                                <item name="paypal-express-applepay" xsi:type="array">
                                                                    <item name="component" xsi:type="string">Magento_PaymentServicesPaypal/js/view/payment/apple-pay-express-checkout</item>
                                                                    <item name="displayArea" xsi:type="string">additional-express-payments-paypal</item>
                                                                    <item name="configSource" xsi:type="string">checkoutConfig</item>
                                                                </item>
                                                            </item>
                                                        </item>
                                                    </item>
                                                </item>
                                            </item>
                                        </item>
                                        <item name="billing-step" xsi:type="array">
                                            <item name="component" xsi:type="string">uiComponent</item>
                                            <item name="children" xsi:type="array">
                                                <item name="payment" xsi:type="array">
                                                    <item name="children" xsi:type="array">
                                                        <item name="customer-email" xsi:type="array">
                                                            <item name="template" xsi:type="string">Magento_PaymentServicesPaypal/form/element/email</item>
                                                            <item name="children" xsi:type="array">
                                                                <item name="paypal-fastlane-email-watermark" xsi:type="array">
                                                                    <item name="component" xsi:type="string">Magento_PaymentServicesPaypal/js/view/form/element/powered-by</item>
                                                                    <item name="displayArea" xsi:type="string">paypal-fastlane-email-watermark</item>
                                                                    <item name="id" xsi:type="string">paypal-fastlane-email-watermark</item>
                                                                </item>
                                                            </item>
                                                        </item>
                                                        <item name="payment-services-express-payments" xsi:type="array">
                                                            <item name="component" xsi:type="string">Magento_PaymentServicesPaypal/js/view/payment/group</item>
                                                            <item name="sortOrder" xsi:type="string">0</item>
                                                            <item name="displayArea" xsi:type="string">customer-email</item>
                                                            <item name="children" xsi:type="array">
                                                                <item name="paypal-express-paypal" xsi:type="array">
                                                                    <item name="component" xsi:type="string">Magento_PaymentServicesPaypal/js/view/payment/smart-buttons-express-checkout</item>
                                                                    <item name="displayArea" xsi:type="string">additional-express-payments-paypal</item>
                                                                    <item name="configSource" xsi:type="string">checkoutConfig</item>
                                                                </item>
                                                                <item name="paypal-express-googlepay" xsi:type="array">
                                                                    <item name="component" xsi:type="string">Magento_PaymentServicesPaypal/js/view/payment/google-pay-express-checkout</item>
                                                                    <item name="displayArea" xsi:type="string">additional-express-payments-paypal</item>
                                                                    <item name="configSource" xsi:type="string">checkoutConfig</item>
                                                                    <item name="id" xsi:type="string">paypal-googlepay-container</item>
                                                                </item>
                                                                <item name="paypal-express-applepay" xsi:type="array">
                                                                    <item name="component" xsi:type="string">Magento_PaymentServicesPaypal/js/view/payment/apple-pay-express-checkout</item>
                                                                    <item name="displayArea" xsi:type="string">additional-express-payments-paypal</item>
                                                                    <item name="configSource" xsi:type="string">checkoutConfig</item>
                                                                </item>
                                                            </item>
                                                        </item>
                                                        <item name="renders" xsi:type="array">
                                                            <item name="children" xsi:type="array">
                                                                <item name="payment_services" xsi:type="array">
                                                                    <item name="component" xsi:type="string">Magento_PaymentServicesPaypal/js/view/payment/method-renderer</item>
                                                                    <item name="methods" xsi:type="array">
                                                                        <item name="payment_services_paypal_hosted_fields" xsi:type="array">
                                                                            <item name="isBillingAddressRequired" xsi:type="boolean">true</item>
                                                                        </item>
                                                                        <item name="payment_services_paypal_smart_buttons" xsi:type="array">
                                                                            <item name="isBillingAddressRequired" xsi:type="boolean">true</item>
                                                                        </item>
                                                                        <item name="payment_services_paypal_apple_pay" xsi:type="array">
                                                                            <item name="isBillingAddressRequired" xsi:type="boolean">true</item>
                                                                        </item>
                                                                        <item name="payment_services_paypal_google_pay" xsi:type="array">
                                                                            <item name="isBillingAddressRequired" xsi:type="boolean">true</item>
                                                                        </item>
                                                                        <item name="payment_services_paypal_apm" xsi:type="array">
                                                                            <item name="isBillingAddressRequired" xsi:type="boolean">true</item>
                                                                        </item>
                                                                    </item>
                                                                </item>
                                                            </item>
                                                        </item>
                                                    </item>
                                                </item>
                                            </item>
                                        </item>
                                    </item>
                                </item>
                                <item name="sidebar" xsi:type="array">
                                    <item name="children" xsi:type="array">
                                        <item name="shipping-information" xsi:type="array">
                                            <item name="template" xsi:type="string">Magento_PaymentServicesPaypal/shipping-information</item>
                                            <item name="children" xsi:type="array">
                                                <item name="paypal-fastlane-shipping-watermark" xsi:type="array">
                                                    <item name="component" xsi:type="string">Magento_PaymentServicesPaypal/js/view/form/element/powered-by</item>
                                                    <item name="displayArea" xsi:type="string">paypal-fastlane-shipping-watermark</item>
                                                    <item name="id" xsi:type="string">paypal-fastlane-shipping-watermark</item>
                                                </item>
                                            </item>
                                        </item>
                                    </item>
                                </item>
                            </item>
                        </item>
                    </item>
                </argument>
            </arguments>
        </referenceBlock>
    </body>
</page>
